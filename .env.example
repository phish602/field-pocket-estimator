# Placeholder-only environment variables for future approved runtime setup.
# Do not put real secrets in this file.
# Service-role keys, database passwords, database connection strings, JWT secrets,
# access tokens, refresh tokens, private keys, and admin keys are forbidden here.
# Real local values belong only in an uncommitted local env file after a future approval gate.
# Runtime wiring remains blocked.

REACT_APP_SUPABASE_URL=replace_with_supabase_project_url
REACT_APP_SUPABASE_ANON_KEY=replace_with_supabase_anon_public_key

# Emergency Gate P1 -- fail-closed cloud opt-in.
# The browser Supabase client is constructed ONLY when this flag is exactly
# "true" AND the deployment is a Vercel Production build. It is the explicit,
# per-environment opt-in that keeps Preview/local/test/unknown builds from ever
# reaching the hosted Supabase project (see src/lib/supabaseRuntimePolicy.js).
#   - Keep it false/unset locally.
#   - Keep it false/unset in Vercel Preview.
#   - Keep it false/unset in Vercel Development.
#   - Only the Vercel Production environment may set it to true.
REACT_APP_ESTIPAID_CLOUD_ENABLED=false

# Supplied automatically by Vercel at build time; do NOT set or spoof these
# locally. The runtime policy reads them to confirm a Production deployment.
# REACT_APP_VERCEL_ENV is one of: production | preview | development.
# REACT_APP_VERCEL_TARGET_ENV, when present, must also be "production".
# (Left commented out on purpose -- Vercel injects the real values.)
# REACT_APP_VERCEL_ENV=
# REACT_APP_VERCEL_TARGET_ENV=
